MICROCMS_SERVICE_DOMAIN=your-service-domain
MICROCMS_API_KEY=your-api-key
SITE_URL=https://your-domain.com
MICROCMS_REVALIDATE=300
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# 任意：ランディング「Latest Posts」
# 方法A（API）：X_BEARER_TOKEN を設定すると最新3件を自動取得してカード表示
# 方法B（APIなし）：X_TWEET_IDS で表示するツイートIDをカンマ区切りで指定 → oEmbed で埋め込み表示
# 未設定時は X_TWEET_IDS のデフォルト3件を oEmbed で表示（APIキー不要）
# X_BEARER_TOKEN=your-bearer-token
# X_TWEET_IDS=1991436077920567426,1976083871675580578,1888149044922617963

# 任意（自動翻訳Webhook）
MICROCMS_WEBHOOK_SECRET=your-secret
OPENAI_API_KEY=your-openai-api-key
